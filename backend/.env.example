# Environment Variables Example
# Copy this file to .env and fill in your actual values

# Database Configuration
DB_CONNECTION_STRING=your_database_connection_string

# JWT Configuration
JWT_SECRET=your_jwt_secret_key

# Server Configuration
PORT=8000
NODE_ENV=development

# Email (Nodemailer)
# — Custom domain (e.g. info@dlthub.org): use SMTP from your host (cPanel → Email Accounts → Connect devices / SMTP settings).
#   Password is the mailbox password you set for that account (not a Google App Password).
EMAIL_USER=info@example.org
EMAIL_PASS=your_mailbox_password
EMAIL_HOST=mail.privateemail.com
EMAIL_PORT=587
# "true" for SSL on port 465; omit or "false" for STARTTLS on 587 (most common)
# SMTP_SECURE=false
# Optional display From header (defaults to EMAIL_USER / SMTP_USER)
# EMAIL_FROM="DLT Africa <info@example.org>"
#
# — Gmail only: leave SMTP_HOST unset and use a Google App Password in EMAIL_PASS.
