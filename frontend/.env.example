# Environment Variables Example
# Copy this file to .env and fill in your actual values

# Cloudinary Configuration
NEXT_PUBLIC_CLOUD_NAME=your_cloudinary_cloud_name
NEXT_PUBLIC_UPLOAD_PRESET=your_cloudinary_upload_preset

# API Configuration (optional; if unset, `lib/apiClient.ts` uses its DEFAULT_BASE_URL)
# Must include `/api/v1`, no trailing slash. This overrides DEFAULT_BASE_URL when set.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Dev only: force localhost even when NEXT_PUBLIC_API_BASE_URL points at production
# NEXT_PUBLIC_FORCE_LOCAL_API=1
